<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Parallel Regression Suite"
       parallel="methods"
       thread-count="5"
       verbose="1"
       data-provider-thread-count="3">

    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.ExtentReportListener"/>
    </listeners>

    <parameter name="browser"  value="chrome"/>
    <parameter name="headless" value="true"/>

    <test name="API Tests" parallel="methods" thread-count="3">
        <classes>
            <class name="tests.api.UserApiTest"/>
            <class name="tests.api.OrderApiTest"/>
        </classes>
    </test>

    <test name="UI Tests" parallel="methods" thread-count="2">
        <classes>
            <class name="tests.ui.LoginTest"/>
            <class name="tests.ui.DashboardTest"/>
        </classes>
    </test>
</suite>